# Google Places API — server-side only. NEVER prefix with NEXT_PUBLIC_ / VITE_
# or anything else that inlines it into the client bundle.
#
# Restrict this key in Google Cloud Console:
#   Application restrictions : None (server calls have no referrer)
#   API restrictions         : Places API (New) ONLY
#   Quota                    : set a daily cap so a leak can't run up a bill
GOOGLE_PLACES_API_KEY=

# One Place ID per office. Get them from the Place ID Finder:
# https://developers.google.com/maps/documentation/places/web-service/place-id
# Search the exact business name + address. See TECHNICAL-MANUAL §6.1.
PLACE_ID_WALDORF=
PLACE_ID_LANHAM=
PLACE_ID_FREDERICK=
PLACE_ID_ROCKVILLE=

# Where validated leads are delivered (case management intake or webhook).
INTAKE_WEBHOOK_URL=
INTAKE_TOKEN=
